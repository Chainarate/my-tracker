# Copy to .env for local runs. NEVER commit a real .env.
# In Harness, the only secret comes from Harness Secrets Manager: GROQ_API_KEY.

# --- The only secret you need ------------------------------------------------
GROQ_API_KEY=your_groq_api_key                # https://console.groq.com/keys

# --- Optional overrides (sane defaults are baked in) -------------------------
GROQ_MODEL=llama-3.3-70b-versatile
REDDIT_RSS_URL=https://old.reddit.com/r/chelseafc/new/.rss
REDDIT_RSS_MAX_ENTRIES=75

# Storage: local | s3 | gcs   (use 'local' for first run; no AWS needed)
STORAGE_BACKEND=local
STORAGE_BUCKET=
STORAGE_PREFIX=chelsea-tracker/
AWS_REGION=ap-southeast-1

OUTPUT_DIR=/data
LOG_LEVEL=INFO
